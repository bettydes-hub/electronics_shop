generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StaffRole {
  OWNER
  SELLER
  ADMIN
}

enum StaffAccountStatus {
  INVITED // Awaiting email verification + username/password on /register
  ACTIVE
}

model User {
  id                   String               @id @default(cuid())
  username             String?              @unique
  email                String               @unique
  name                 String
  passwordHash         String?
  role                 StaffRole
  staffStatus          StaffAccountStatus   @default(ACTIVE)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  inviteCodes          StaffInviteCode[]
  passwordResetTokens  PasswordResetToken[]
}

model PasswordResetToken {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenDigest String   @unique
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@index([userId])
}

model StaffInviteCode {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash  String
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
}

enum PromotionScope {
  PRODUCT
  CATEGORY
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique // English (primary); URLs and product links use this + slug
  nameAm    String?   // አማርኛ — optional; storefront falls back to English
  slug      String?   // e.g. "phones" for URL
  createdAt DateTime  @default(now())
  products  Product[]
  promotions Promotion[]
}

model Product {
  id          String   @id @default(cuid())
  name        String   // English (primary)
  description String?  // English (primary)
  nameAm      String?  // አማርኛ — optional; falls back to English in storefront
  descriptionAm String?
  price       Float
  costPrice   Float?   // For profit calculation
  category    String?  // Legacy - keep for backwards compat
  categoryId  String?
  categoryRef Category? @relation(fields: [categoryId], references: [id])
  imageUrl    String?   // Legacy - first image, keep for compatibility
  imageUrls   String[]  @default([]) // count range from ShopSettings (hard-capped in app)
  stock       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  purchases   Purchase[]
  sales       Sale[]
  orderItems  OrderItem[]
  reviews     Review[]
  promotions  Promotion[]
  dynamicPricing DynamicPricingRule?
}

model Review {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  authorName String   @default("Customer")
  rating     Int      // 1–5
  comment    String?
  createdAt  DateTime @default(now())
}

// Owner: records newly purchased stock
model Purchase {
  id             String   @id @default(cuid())
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  quantity       Int
  unitCost       Float    // what you paid per unit (supplier cost)
  unitSalePrice  Float?   // retail price per unit at time of purchase (updates catalog)
  totalCost      Float
  notes          String?
  createdAt      DateTime @default(now())
}

// Owner: records bills and other expenses
model Expense {
  id          String   @id @default(cuid())
  description String
  amount      Float
  category    String?  // e.g. rent, electricity, etc.
  period      String   @default("MONTHLY") // WEEKLY, MONTHLY, THREE_MONTHS, SIX_MONTHS, YEARLY — what the amount covers
  createdAt   DateTime @default(now())
}

// Seller: records daily sales (reduces stock)
model Sale {
  id         String   @id @default(cuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  quantity   Int
  unitPrice  Float
  total      Float
  createdAt  DateTime @default(now())
}

model Promotion {
  id          String          @id @default(cuid())
  name        String
  nameAm      String?         // አማርኛ — optional; falls back to English in storefront
  scope       PromotionScope
  productId   String?
  product     Product?        @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId  String?
  categoryRef Category?       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  percentOff  Float           // 1–100
  startsAt    DateTime
  endsAt      DateTime
  isFlashSale Boolean         @default(false) // short window / highlight in admin
  active      Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([active, startsAt, endsAt])
  @@index([productId])
  @@index([categoryId])
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  percentOff    Float?
  fixedOff      Float?
  maxUses       Int?
  usedCount     Int       @default(0)
  minOrderTotal Float?    @default(0)
  startsAt      DateTime?
  endsAt      DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orders        Order[]
}

/// Demand-based adjustments on top of list price (before %-off promotions).
model DynamicPricingRule {
  id                       String   @id @default(cuid())
  productId                String   @unique
  product                  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  enabled                  Boolean  @default(false)
  lowStockThreshold        Int      @default(5)
  lowStockMarkupPercent    Float    @default(0)
  highStockThreshold       Int      @default(100)
  highStockDiscountPercent Float    @default(0)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

// Customer orders (reduces stock, delivery + payment)
model Order {
  id             String      @id @default(cuid())
  customerPhone  String
  customerName   String?
  deliveryAddress String?
  subtotal       Float       @default(0) // lines before coupon
  discountTotal  Float       @default(0) // coupon discount
  total          Float
  couponId       String?
  coupon         Coupon?     @relation(fields: [couponId], references: [id], onDelete: SetNull)
  couponCodeSnapshot String? // code text at checkout
  status         String     @default("PENDING") // PENDING, PAID, DELIVERED
  paymentMethod  String?    // e.g. cash, mobile_money
  createdAt      DateTime   @default(now())
  items          OrderItem[]

  @@index([couponId])
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id])
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  unitPrice Float
}

// Single row id "default": customer footer / store contact, editable by admin
model ShopSettings {
  id           String   @id
  storeName    String
  address      String   @default("")
  phone        String   @default("")
  tiktokUrl    String   @default("")
  instagramUrl String   @default("")
  telegramUrl  String   @default("")
  productImageCountMin Int @default(1) // allowed range for product imageUrls length
  productImageCountMax Int @default(6)
  updatedAt    DateTime @updatedAt
}
