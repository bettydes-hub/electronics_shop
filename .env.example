# PostgreSQL database
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# Local example: postgresql://postgres:password@localhost:5432/electronics_shop
# Cloud options: Neon, Supabase, Railway, etc.
DATABASE_URL="postgresql://postgres:password@localhost:5432/electronics_shop"

# Staff session signing (JWT in HttpOnly cookie). Min 32 characters. Required in production.
# STAFF_SESSION_SECRET="generate-a-long-random-string-at-least-32-chars"

# Optional shared rate-limit backend (recommended in production / multi-instance):
# UPSTASH_REDIS_REST_URL="https://..."
# UPSTASH_REDIS_REST_TOKEN="..."

# Cloudinary - get free account at https://cloudinary.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloud_name"
CLOUDINARY_API_KEY="your_api_key"
CLOUDINARY_API_SECRET="your_api_secret"

# Public site URL (no trailing slash). Used in password-reset emails. Production: use https://
# Locally you can omit it; the app uses the incoming request host.
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- HTTPS / transport security (production behind TLS) ---
# Staff session cookies already use Secure in production (NODE_ENV=production).
# On Vercel, HSTS is added automatically; elsewhere set FORCE_HSTS=true only if every user-facing URL is HTTPS.
# FORCE_HSTS=true
# DISABLE_HSTS=true
# Optional: HTTP→HTTPS redirect when your host sends x-forwarded-proto (set on Vercel, or opt in self-hosted):
# ENFORCE_HTTPS_REDIRECT=true
# ENFORCE_HTTPS_REDIRECT=false

# First admin: open http://localhost:3000/setup in the browser (only works while DB has zero users).
# Optional CLI alternative: npm run db:seed with BOOTSTRAP_ADMIN_PASSWORD below (min 8 chars).
# BOOTSTRAP_ADMIN_PASSWORD="change_me_at_least_8"
# BOOTSTRAP_ADMIN_USERNAME=admin
# BOOTSTRAP_ADMIN_EMAIL=admin@localhost
# BOOTSTRAP_ADMIN_NAME=Administrator

# --- Email (staff verification codes, invites, transactional) ---
# Tried in order: SMTP_* (if host, username, password all set) → else EMAIL_USER + EMAIL_PASS
#
# Option B — Gmail shorthand (App Password, not your normal password):
# https://myaccount.google.com/apppasswords
EMAIL_USER="you@gmail.com"
EMAIL_PASS="your_16_char_app_password"
# Use exactly one EMAIL_PASS line; in .env the last duplicate key wins and can hide your real app password.
#
# Option A — Generic SMTP (comment out EMAIL_USER / EMAIL_PASS above if you use this instead)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=465
# SMTP_USERNAME="you@gmail.com"
# SMTP_PASSWORD="your_16_char_app_password"
# FROM_EMAIL="you@gmail.com"
# If port 465 is blocked, try: SMTP_PORT=587

# --- Store info (shown on /customer footer) ---
NEXT_PUBLIC_SHOP_NAME="Electronics Shop"
NEXT_PUBLIC_SHOP_ADDRESS="123 Main Street, Your City"
# NEXT_PUBLIC_SHOP_ADDRESS="Line 1\nLine 2"  (use \n for two lines in .env)
NEXT_PUBLIC_SHOP_PHONE="+1 234 567 890"
NEXT_PUBLIC_SHOP_TIKTOK_URL="https://www.tiktok.com/@yourshop"
NEXT_PUBLIC_SHOP_INSTAGRAM_URL="https://instagram.com/yourshop"
NEXT_PUBLIC_SHOP_TELEGRAM_URL="https://t.me/yourshop"
